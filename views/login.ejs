<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= settings.appName %> - Login</title>
  <link rel="icon" href="/static/favicon.svg">
  <link rel="stylesheet" href="/static/style.css">

  <style>
    body::before{
      background-image:
        linear-gradient(rgba(7,12,24,.62), rgba(7,12,24,.80)),
        url('<%= settings.backgroundImageUrl || "/static/default-bg.svg" %>');
      filter: blur(<%= settings.blurStrength || 14 %>px);
      transform: scale(1.06);
    }

    .login-page{
      display:flex;
      align-items:center;
      justify-content:center;
      min-height:100vh;
      padding:24px;
      position:relative;
      overflow:hidden;
    }

    .vip-orb{
      position:absolute;
      border-radius:50%;
      filter: blur(60px);
      opacity:.28;
      pointer-events:none;
      z-index:1;
    }

    .vip-orb.one{
      width:260px;
      height:260px;
      background:#00d9ff;
      top:8%;
      right:12%;
    }

    .vip-orb.two{
      width:320px;
      height:320px;
      background:#6a7cff;
      bottom:10%;
      left:10%;
    }

    .login-card{
      width:min(470px, 100%);
      padding:34px 28px 26px;
      border-radius:30px;
      position:relative;
      overflow:hidden;
      border:1px solid rgba(255,255,255,.10);
      background:linear-gradient(180deg, rgba(20,28,48,.68), rgba(11,18,34,.72));
      box-shadow:
        0 24px 70px rgba(0,0,0,.35),
        inset 0 1px 0 rgba(255,255,255,.06);
      z-index:3;
    }

    .login-card::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        linear-gradient(135deg, rgba(0,217,255,.10), transparent 32%),
        linear-gradient(315deg, rgba(106,124,255,.10), transparent 35%);
      pointer-events:none;
    }

    .login-inner{
      position:relative;
      z-index:2;
    }

    .top-badge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      margin:0 auto 16px;
      padding:8px 14px;
      border-radius:999px;
      background:rgba(255,255,255,.05);
      border:1px solid rgba(255,255,255,.08);
      color:#dff8ff;
      font-size:12px;
      font-weight:700;
      letter-spacing:.7px;
      text-transform:uppercase;
    }

    .top-badge-dot{
      width:8px;
      height:8px;
      border-radius:50%;
      background:#00e1ff;
      box-shadow:0 0 12px #00e1ff;
    }

    .brand-wrap{
      text-align:center;
      margin-bottom:18px;
    }

    .brand-logo{
      width:124px;
      max-width:100%;
      display:block;
      margin:0 auto 16px;
      filter:
        drop-shadow(0 0 12px rgba(0,209,255,.24))
        drop-shadow(0 0 28px rgba(106,124,255,.16));
      transition:transform .25s ease, filter .25s ease;
    }

    .brand-logo:hover{
      transform:scale(1.05);
    }

    .brand-title{
      margin:0;
      font-size:32px;
      font-weight:900;
      line-height:1.1;
      color:#fff;
    }

    .brand-desc{
      margin:10px 0 0;
      color:var(--muted);
      font-size:14px;
      line-height:1.8;
    }

    .developer-box{
      margin:22px 0 20px;
      padding:14px 16px;
      border-radius:22px;
      background:linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.03));
      border:1px solid rgba(255,255,255,.08);
      display:flex;
      align-items:center;
      gap:13px;
    }

    .developer-avatar{
      width:56px;
      height:56px;
      border-radius:50%;
      object-fit:cover;
      border:2px solid rgba(0, 225, 255, .32);
      flex-shrink:0;
    }

    .developer-meta{
      min-width:0;
      display:flex;
      flex-direction:column;
    }

    .developer-label{
      font-size:11px;
      color:#99ecff;
      text-transform:uppercase;
      letter-spacing:1.6px;
      font-weight:800;
      margin-bottom:4px;
    }

    .developer-name{
      font-size:17px;
      font-weight:900;
      color:#fff;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .developer-user{
      font-size:13px;
      color:var(--muted);
      margin-top:3px;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }

    .dev-status{
      margin-right:auto;
      display:flex;
      align-items:center;
      gap:8px;
      color:#bff7ff;
      font-size:12px;
      font-weight:700;
      flex-shrink:0;
    }

    .dev-status-dot{
      width:9px;
      height:9px;
      border-radius:50%;
      background:#00f0a8;
      box-shadow:0 0 14px rgba(0,240,168,.75);
    }

    .field{
      margin-bottom:12px;
    }

    .field label{
      display:block;
      margin-bottom:7px;
      font-size:13px;
      color:#dbe7ff;
      font-weight:700;
    }

    .field input{
      width:100%;
      height:52px;
      border-radius:16px;
      border:1px solid rgba(255,255,255,.09);
      background:rgba(8,14,28,.72);
      color:#fff;
      padding:0 16px;
      font-size:15px;
    }

    .vip-btn{
      width:100%;
      height:54px;
      margin-top:6px;
      border:none;
      border-radius:16px;
      color:#fff;
      font-size:16px;
      font-weight:900;
      cursor:pointer;
      background:linear-gradient(90deg, #6a7cff, #00d9ff);
    }

    .footer-note{
      text-align:center;
      margin-top:16px;
      font-size:12px;
      color:rgba(255,255,255,.58);
      line-height:1.9;
    }

    .divider{
      margin:18px 0 16px;
      display:flex;
      align-items:center;
      gap:10px;
      color:#a8b8dc;
      font-size:12px;
      font-weight:700;
    }

    .divider::before,
    .divider::after{
      content:"";
      height:1px;
      flex:1;
      background:linear-gradient(90deg, transparent, rgba(255,255,255,.12), transparent);
    }

    .alert.error{
      margin:0 0 14px;
      border-radius:16px;
      background:rgba(255,100,124,.12);
      border:1px solid rgba(255,100,124,.20);
      color:#ffe3e9;
      padding:12px 14px;
      font-size:13px;
      font-weight:700;
    }
  </style>
</head>

<body class="login-page">
  <div class="overlay"></div>
  <div class="vip-orb one"></div>
  <div class="vip-orb two"></div>

  <div class="login-card glass">
    <div class="login-inner">
      <div class="brand-wrap">
        <div class="top-badge">
          <span class="top-badge-dot"></span>
          VIP CONTROL PANEL
        </div>

        <img src="/static/logo.png" class="brand-logo" alt="Syria Store Logo">
        <h1 class="brand-title"><%= settings.appName %></h1>
        <p class="brand-desc"><%= settings.siteDescription %></p>
      </div>

      <div class="developer-box">
        <img
          src="<%= developer ? developer.avatar : '/static/developer.png' %>"
          class="developer-avatar"
          alt="Developer Avatar"
        >

        <div class="developer-meta">
          <span class="developer-label">Developer</span>
          <span class="developer-name"><%= developer ? (developer.displayName || developer.username) : 'Alaa Dev' %></span>
          <span class="developer-user">@<%= developer ? developer.username : 'syria.store' %></span>
        </div>

        <div class="dev-status">
          <span class="dev-status-dot"></span>
          Online
        </div>
      </div>

      <% if (error) { %>
        <div class="alert error"><%= error %></div>
      <% } %>

      <div class="divider">تسجيل الدخول</div>

      <form method="POST" action="/login">
        <div class="field">
          <label>الإيميل</label>
          <input type="email" name="email" placeholder="أدخل الإيميل" required>
        </div>

        <div class="field">
          <label>كلمة المرور</label>
          <input type="password" name="password" placeholder="أدخل كلمة المرور" required>
        </div>

        <button class="vip-btn" type="submit">دخول إلى اللوحة</button>
      </form>

      <div class="footer-note">
        Syria Store VIP Panel — واجهة احترافية لإدارة النظام والإعدادات والصلاحيات
      </div>
    </div>
  </div>
</body>
</html>
