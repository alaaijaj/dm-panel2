<!DOCTYPE html><html lang="ar" dir="rtl"><head><meta charset="UTF-8"><title>Users</title><link rel="stylesheet" href="/static/style.css"></head><body><div class="content"><h1>Users - Owner Only</h1><div class="table"><div class="thead"><span>Email</span><span>Role</span><span>Discord ID</span><span>Status</span></div><% users.forEach(u=>{ %><div class="trow" style="grid-template-columns:1fr 120px 1fr 120px;"><span><%= u.email %></span><span><%= u.role %></span><span><%= u.discordUserId || '-' %></span><span><%= u.isActive ? 'مفعل' : 'موقوف' %></span></div><% }) %></div></div></body></html>