<!DOCTYPE html><html lang="ar" dir="rtl"><head><meta charset="UTF-8"><title>Subscribers</title><link rel="stylesheet" href="/static/style.css"></head><body><div class="content"><h1>Subscribers - Owner Only</h1><div class="table"><div class="thead"><span>Name</span><span>Email</span><span>Status</span><span>Plan</span></div><% subscribers.forEach(s=>{ %><div class="trow"><span><%= s.name || '-' %></span><span><%= s.email %></span><span><%= s.active ? 'مفعل' : 'موقوف' %></span><span><%= s.plan || '-' %></span></div><% }) %></div></div></body></html>