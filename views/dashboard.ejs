<!DOCTYPE html><html lang="ar" dir="rtl"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/><title><%= settings.appName %></title><link rel="icon" href="/static/favicon.svg"><link rel="stylesheet" href="/static/style.css"><style>body::before{background-image:linear-gradient(rgba(9,13,24,.62), rgba(9,13,24,.75)), url('<%= settings.backgroundImageUrl || "/static/default-bg.svg" %>');filter: blur(<%= settings.blurStrength || 14 %>px);}</style></head><body><div class="overlay"></div><div class="layout"><aside class="sidebar glass"><div class="brand"><img src="/static/favicon.svg" alt="logo"/><div><h1><%= settings.appName %></h1><p><%= settings.siteDescription %></p></div></div><div class="profile-card"><div><strong>المستخدم الحالي:</strong> <%= currentUser.email %></div><div><strong>الصلاحية:</strong> <%= currentUser.role %></div></div><% if (developer) { %><div class="developer-card"><img src="<%= developer.avatar %>" alt="dev"/><div><div class="label">Developer</div><div class="name"><%= developer.displayName %></div><div class="muted">@<%= developer.username %></div></div></div><% } %><nav><a href="#send">الإرسال</a><a href="#stats">الإحصائيات</a><a href="#subs">المشتركين</a><a href="#users">مستخدمي اللوحة</a><a href="#settings">الإعدادات</a><a href="#logs">السجل</a></nav><a class="logout" href="/logout">تسجيل الخروج</a></aside><main class="content"><% if (result && result.error) { %><div class="alert error"><%= result.error %></div><% } %><% if (result && !result.error) { %><div class="alert success">تم الإرسال — المستهدف: <%= result.totalTargets %> | نجح: <%= result.sent %> | فشل: <%= result.failed %></div><% } %><section id="stats" class="glass hero"><div class="stats-grid"><div class="stat"><span>عدد المشتركين</span><strong><%= subscribersCount %></strong></div><div class="stat"><span>سعر الاشتراك الشهري</span><strong><%= settings.monthlyPrice %> <%= settings.currency %></strong></div><div class="stat"><span>عدد مستخدمي اللوحة</span><strong><%= users.length %></strong></div><div class="stat"><span>الوضع الآمن</span><strong><%= settings.allowRoleMessagingOnly ? "مفعل" : "غير مفعل" %></strong></div></div></section><section id="send" class="glass card"><h2>إرسال آمن</h2><p class="note">هذه النسخة تسمح بالإرسال إلى عضو/عدة أعضاء/رتبة محددة. الإرسال إلى الجميع غير مفعّل.</p><form action="/send" method="POST" enctype="multipart/form-data"><div class="grid"><label><span>السيرفر</span><select name="guildId" id="guildSelect" required><option value="">اختر السيرفر</option><% guilds.forEach(g => { %><option value="<%= g.id %>"><%= g.name %> (<%= g.members %>)</option><% }) %></select></label><label><span>اسم السيرفر</span><input type="text" id="guildNamePreview" readonly placeholder="يظهر تلقائيًا"/></label><label><span>نوع الاستهداف</span><select name="targetType" id="targetType" required><option value="single">عضو واحد</option><option value="multiple">عدة أعضاء</option><option value="role">رتبة محددة</option></select></label><label id="singleWrap"><span>عضو واحد</span><select name="singleUserId" id="singleUserId"></select></label><label id="multipleWrap" class="hidden"><span>عدة أعضاء</span><select name="multipleUserIds" id="multipleUserIds" multiple size="8"></select></label><label id="roleWrap" class="hidden"><span>الرتبة</span><select name="roleId" id="roleId"></select></label><label class="toggle"><input type="checkbox" name="useEmbed" checked><span>استخدام Embed</span></label><label><span>عنوان الرسالة</span><input type="text" name="title"></label><label class="full"><span>الوصف</span><textarea name="description" rows="5"></textarea></label><label class="full"><span>نص عادي إضافي</span><textarea name="plainText" rows="3"></textarea></label><label><span>لون</span><input type="color" name="color" value="#5865F2"></label><label><span>تذييل</span><input type="text" name="footer"></label><label><span>رابط صورة</span><input type="url" name="imageUrl"></label><label><span>أو ارفع صورة</span><input type="file" name="image" accept="image/*"></label></div><button class="primary-btn">إرسال</button></form></section><section id="subs" class="glass card"><h2>المشتركين</h2><% if (currentUser.role === 'owner') { %><form action="/subscribers/add" method="POST" class="inline-form"><input type="text" name="name" placeholder="الاسم" required><input type="email" name="email" placeholder="الإيميل" required><button class="secondary-btn">إضافة مشترك</button></form><% } %><div class="table"><div class="thead"><span>الاسم</span><span>الإيميل</span><span>الحالة</span><span>الإجراء</span></div><% subscribers.forEach(s => { %><div class="trow"><span><%= s.name || '-' %></span><span><%= s.email %></span><span><%= s.active ? 'مفعل' : 'موقوف' %></span><span><% if (currentUser.role === 'owner') { %><form action="/subscribers/toggle/<%= s.id %>" method="POST"><button class="mini-btn"><%= s.active ? 'إيقاف' : 'تفعيل' %></button></form><% } %></span></div><% }) %></div></section><section id="users" class="glass card"><h2>مستخدمي اللوحة</h2><% if (currentUser.role === 'owner') { %><form action="/users/add" method="POST" class="inline-form"><input type="email" name="email" placeholder="Email" required><input type="text" name="password" placeholder="Password" required><select name="role"><option value="admin">admin</option><option value="viewer">viewer</option></select><button class="secondary-btn">إضافة مستخدم لوحة</button></form><% } %><div class="table"><div class="thead"><span>الإيميل</span><span>الدور</span><span>الحالة</span><span>الإجراء</span></div><% users.forEach(u => { %><div class="trow"><span><%= u.email %></span><span><%= u.role %></span><span><%= u.isActive ? 'مفعل' : 'موقوف' %></span><span><% if (currentUser.role === 'owner' && u.role !== 'owner') { %><form action="/users/toggle/<%= u.id %>" method="POST"><button class="mini-btn"><%= u.isActive ? 'إيقاف' : 'تفعيل' %></button></form><% } %></span></div><% }) %></div></section><% if (currentUser.role === 'owner') { %><section id="settings" class="glass card"><h2>الإعدادات</h2><form action="/settings" method="POST"><div class="grid"><label><span>اسم الموقع</span><input type="text" name="appName" value="<%= settings.appName %>"></label><label><span>وصف الموقع</span><input type="text" name="siteDescription" value="<%= settings.siteDescription %>"></label><label><span>سعر الاشتراك الشهري</span><input type="number" step="0.01" name="monthlyPrice" value="<%= settings.monthlyPrice %>"></label><label><span>العملة</span><input type="text" name="currency" value="<%= settings.currency %>"></label><label class="full"><span>رابط الخلفية</span><input type="url" name="backgroundImageUrl" value="<%= settings.backgroundImageUrl %>"></label><label><span>قوة البلور</span><input type="number" name="blurStrength" value="<%= settings.blurStrength %>" min="0" max="40"></label><label><span>Discord ID للديفلوبر</span><input type="text" name="developerDiscordId" value="<%= settings.developerDiscordId %>"></label><label class="toggle"><input type="checkbox" name="allowRoleMessagingOnly" <%= settings.allowRoleMessagingOnly ? "checked" : "" %>><span>تفعيل الوضع الآمن</span></label></div><button class="primary-btn">حفظ الإعدادات</button></form></section><% } %><section id="logs" class="glass card"><h2>سجل الاستخدام</h2><div class="table"><div class="thead logs-head"><span>الوقت</span><span>النوع</span><span>من</span><span>التفاصيل</span></div><% logs.forEach(log => { %><div class="trow logs-row"><span><%= new Date(log.time).toLocaleString('de-DE') %></span><span><%= log.type %></span><span><%= log.actorEmail || '-' %></span><span><%= log.message || log.plainTextPreview || '-' %></span></div><% }) %></div></section></main></div><script>const guildSelect=document.getElementById('guildSelect');const guildNamePreview=document.getElementById('guildNamePreview');const targetType=document.getElementById('targetType');const singleWrap=document.getElementById('singleWrap');const multipleWrap=document.getElementById('multipleWrap');const roleWrap=document.getElementById('roleWrap');const singleUserId=document.getElementById('singleUserId');const multipleUserIds=document.getElementById('multipleUserIds');const roleId=document.getElementById('roleId');function toggleTargetFields(){const v=targetType.value;singleWrap.classList.toggle('hidden',v!=='single');multipleWrap.classList.toggle('hidden',v!=='multiple');roleWrap.classList.toggle('hidden',v!=='role');}async function loadGuildData(){if(!guildSelect.value) return;const res=await fetch('/guild-data/'+guildSelect.value);const data=await res.json();if(!data.ok) return;guildNamePreview.value=data.guildName||'';singleUserId.innerHTML='';multipleUserIds.innerHTML='';roleId.innerHTML='';data.users.forEach(user=>{let a=document.createElement('option');a.value=user.id;a.textContent=user.label;singleUserId.appendChild(a);let b=document.createElement('option');b.value=user.id;b.textContent=user.label;multipleUserIds.appendChild(b);});data.roles.forEach(role=>{let c=document.createElement('option');c.value=role.id;c.textContent=`${role.name} (${role.count})`;roleId.appendChild(c);});}targetType.addEventListener('change',toggleTargetFields);guildSelect.addEventListener('change',loadGuildData);toggleTargetFields();</script></body></html>
