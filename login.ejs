<!DOCTYPE html><html lang="ar" dir="rtl"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/><title><%= settings.appName %> - Login</title><link rel="icon" href="/static/favicon.svg"><link rel="stylesheet" href="/static/style.css"><style>body::before{background-image:linear-gradient(rgba(9,13,24,.60), rgba(9,13,24,.78)), url('<%= settings.backgroundImageUrl || "/static/default-bg.svg" %>');filter: blur(<%= settings.blurStrength || 14 %>px);}</style></head><body class="login-page"><div class="overlay"></div><div class="login-card glass"><img src="/static/favicon.svg" class="login-logo" alt="logo"/><h1><%= settings.appName %></h1><p><%= settings.siteDescription %></p><% if (error) { %><div class="alert error"><%= error %></div><% } %><form method="POST" action="/login"><label><span>الإيميل</span><input type="email" name="email" required></label><label><span>كلمة المرور</span><input type="password" name="password" required></label><button class="primary-btn full-btn">دخول</button></form></div></body></html>